# ===========================================
# SENSITIVE FILES - DO NOT COMMIT
# ===========================================
# Application configuration with credentials (use application-local.yml for local secrets)
backend/src/main/resources/application-local.yml

# Machine-specific run scripts
backend/run.cmd

# Environment files
.env
.env.local
.env.*.local
*.env
.env.docker

# ===========================================
# BACKEND (Java/Maven/Spring Boot)
# ===========================================
# Maven
backend/target/
backend/.mvn/wrapper/maven-wrapper.jar
**/target/
*.class

# Maven Wrapper - keep the scripts but not the jar
# backend/.mvn/ is excluded except for wrapper properties
backend/.mvn/wrapper/*.jar

# Build outputs
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar

# Log files
*.log
backend/logs/
backend/spring.log

# ===========================================
# FRONTEND (React/Node.js)
# ===========================================
# Dependencies
frontend/node_modules/
node_modules/
**/node_modules/

# Build outputs
frontend/dist/
frontend/build/
frontend/.next/
frontend/out/

# Frontend environment files
frontend/.env
frontend/.env.local
frontend/.env.*.local

# Testing
frontend/coverage/

# Production
frontend/build

# ===========================================
