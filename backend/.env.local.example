# Local development environment variables for backend run.cmd
# Copy this file to .env.local and fill real values.
# .env.local should stay uncommitted.

# Database (Neon recommended)
# Use JDBC URL format. Example:
# DB_URL=jdbc:postgresql://ep-xxxx-pooler.us-east-1.aws.neon.tech/neondb?sslmode=require&channel_binding=require
# DB_USERNAME=neondb_owner
# DB_PASSWORD=your_neon_password

# Database (local postgres fallback if DB_URL is not set)
# DB_HOST=localhost
# DB_PORT=5433
# DB_NAME=shelf_db
# DB_USERNAME=postgres
# DB_PASSWORD=admin

# Google OAuth2 (required to enable Google login locally)
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# Must match your frontend callback route
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth/callback

# Comma-separated allowlist patterns for OAuth redirect_uri override
# Use this to enable extension callback URLs safely.
# Example:
# OAUTH2_ALLOWED_REDIRECT_URI_PATTERNS=http://localhost:3000/oauth/callback,chrome-extension://*/callback/index.html,edge-extension://*/callback/index.html
OAUTH2_ALLOWED_REDIRECT_URI_PATTERNS=http://localhost:3000/oauth/callback

# Comma-separated frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# Optional CORS origin patterns for extension schemes
# Example: CORS_ALLOWED_ORIGIN_PATTERNS=chrome-extension://*,edge-extension://*
CORS_ALLOWED_ORIGIN_PATTERNS=

# Optional JWT secret override
# JWT_SECRET=your_base64_secret
