# ─────────────────────────────────────────────────────────────────
# Docker / Production environment variables for Shelf
# Copy this to .env.docker and fill in your real values.
# NEVER commit .env.docker — it is in .gitignore.
# ─────────────────────────────────────────────────────────────────

# PostgreSQL
DB_USERNAME=postgres
DB_PASSWORD=change_me_strong_password

# JWT — generate with: openssl rand -base64 64
JWT_SECRET=replace_with_your_base64_encoded_secret_minimum_256_bits

# Google OAuth2 — from https://console.cloud.google.com/
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your_google_client_secret

# OAuth2 callback (must match Google Console authorized redirect URIs)
OAUTH2_REDIRECT_URI=http://localhost:3000/oauth/callback

# CORS — comma-separated list of allowed frontend origins
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend API keys
VITE_TMDB_API_KEY=your_tmdb_api_key
VITE_RAWG_API_KEY=your_rawg_api_key
